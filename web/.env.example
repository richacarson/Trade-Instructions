# Supabase project credentials for the web app.
# Copy this file to web/.env.local and fill in real values.
# Find these in the Supabase dashboard: Project Settings > API.
#
# The anon key is safe to expose in a client bundle (RLS protects the data).
# NEVER put the service_role key in this file.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
